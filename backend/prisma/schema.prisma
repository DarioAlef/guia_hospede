datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Property {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  type          String
  bedrooms      Int
  bathrooms     Int
  guestCapacity Int

  address     Json
  operational Json
  rules       Json
  amenities   Json
  images      Json
  host        Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guidebook Guidebook?
}

model Guidebook {
  id         String   @id @default(cuid())
  propertyId String   @unique
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  restaurants       Json
  attractions       Json
  essentialServices Json
  seasonalTip       String
  welcomeMessage    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
