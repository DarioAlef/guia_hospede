# Obrigatório: string de conexão PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/guia_hospede

# Porta do servidor backend (default: 3001)
PORT=3001

# Ambiente de execução (development | production | test)
NODE_ENV=development

# Chave da API Groq Cloud — usada nas fases guidebook/chat (não obrigatória nesta fase)
# Modelo utilizado: openai/gpt-oss-120b
GROQ_API_KEY=
